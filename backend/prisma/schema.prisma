generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model Prediction {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  rainfall    Float[]
  lakeLevel   Float[]
  hours       Json
  bounds      Json
  demPng      String
  lakePng     String
  thresholds  Json

  // (optional summary fields you can add later)
  maxFloodedLandPct  Float?
  maxDepthM          Float?
  highestWarning     String?

  @@map("predictions")
}