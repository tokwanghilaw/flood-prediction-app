generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Prediction {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  rainfall    Float[]
  lakeLevel   Float[]
  hours       Json     // full hours array from API
  bounds      Json
  demPng      String
  lakePng     String
  thresholds  Json
  maxFloodedLandPct  Float?
  maxDepthM          Float?
  highestWarning     String?
  @@map("predictions")
}